<UserControl x:Class="KeyStats.Views.Controls.KeyDistributionPieChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Canvas x:Name="PieCanvas" ClipToBounds="True"/>
        <Border x:Name="CenterHole"
                Width="108"
                Height="108"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource SubtleFillBrush}"
                BorderThickness="1"
                CornerRadius="54"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsHitTestVisible="False">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="8">
                <TextBlock x:Name="CenterKeyText"
                           Text=""
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock x:Name="CenterCountText"
                           Margin="0,6,0,0"
                           FontSize="11"
                           TextAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock x:Name="CenterPercentText"
                           Margin="0,2,0,0"
                           FontSize="11"
                           TextAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
